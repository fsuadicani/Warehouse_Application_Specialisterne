## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/
out/
[Bb]uild/
[Ll]og/

# Visual Studio cache/options
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet
*.nupkg
*.snupkg
packages/
*.nuget.props
*.nuget.targets

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Entity Framework
Migrations/

# Rider
.idea/

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# DotCover
*.dotCover

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Compiled DLLs and executables
*.dll
*.exe
*.app
*.appx
*.apk
*.so
*.dylib

# Publish output
publish/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Generated files
*.g.cs
*.g.i.cs
*.designer.cs

# Backup files
*.bak
*.orig

# OS-specific
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store

.env